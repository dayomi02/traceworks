@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix pm:   <https://ontology.example.org/project-management#> .

# ══════════════════════════════════════════════════════════════════
#  온톨로지 메타데이터
#  이 온톨로지는 실무자의 업무 진행 상황을 자동으로 수집·해석하여
#  프로젝트 관리 및 인력 추천을 지원하는 AI 기반 시스템을 위한
#  지식 구조(Knowledge Schema)를 정의합니다.
# ══════════════════════════════════════════════════════════════════

<https://ontology.example.org/project-management>
    a owl:Ontology ;
    dcterms:title "AI 기반 프로젝트 관리 온톨로지"@ko ;
    dcterms:title "AI-based Project Management Ontology"@en ;
    dcterms:description """
        실무자가 평소처럼 Figma, GitHub, Notion, Slack 등의 도구를 사용하면,
        시스템이 해당 로그를 수집하고 온톨로지를 통해 의미를 부여합니다.
        이를 통해 WBS 자동화, 맥락 인식 알림, 인력 추천, 자동 보고서 등을
        제공하는 서비스 레이어를 지원합니다.
    """@ko ;
    dcterms:created "2025-01-01"^^xsd:date ;
    owl:versionInfo "1.0.0" .


# ══════════════════════════════════════════════════════════════════
#  LAYER 1 — 핵심 엔티티 클래스 (Core Entities)
#
#  시스템의 기본 주체와 대상을 정의합니다.
#  Person(실무자), Organization(조직), Project(프로젝트),
#  Task(업무), Skill(역량)이 이 레이어에 속합니다.
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
#  Person (실무자 / 조직 구성원)
#  프로젝트에 참여하는 모든 사람을 표현합니다.
#  역할(PM, 기획자, 개발자, 디자이너 등), 보유 스킬, 과거 수행 이력,
#  협업 관계 등이 이 클래스에 누적됩니다.
# ──────────────────────────────────────────────────────────────────
pm:Person
    a owl:Class ;
    rdfs:label "실무자"@ko , "Person"@en ;
    rdfs:comment """
        프로젝트에 참여하는 개인을 나타냅니다.
        업무 툴 로그(GitHub 커밋, Figma 수정, Notion 편집, Slack 메시지)로부터
        역량과 수행 이력이 자동으로 축적됩니다.
        인력 추천, 커리어 그래프, 자동 보고서의 기본 단위입니다.
    """@ko .

pm:personId
    a owl:DatatypeProperty ;
    rdfs:label "실무자 식별자"@ko ;
    rdfs:comment "시스템 내 고유 식별자. 각 도구(GitHub ID, Figma ID 등)와 매핑됩니다."@ko ;
    rdfs:domain pm:Person ;
    rdfs:range xsd:string .

pm:personName
    a owl:DatatypeProperty ;
    rdfs:label "이름"@ko ;
    rdfs:domain pm:Person ;
    rdfs:range xsd:string .

pm:email
    a owl:DatatypeProperty ;
    rdfs:label "이메일"@ko ;
    rdfs:comment "알림 발송 및 계정 연동에 사용됩니다."@ko ;
    rdfs:domain pm:Person ;
    rdfs:range xsd:string .

pm:role
    a owl:DatatypeProperty ;
    rdfs:label "역할"@ko ;
    rdfs:comment "PM, 기획자, 개발자, 디자이너, QA 등 조직 내 역할입니다."@ko ;
    rdfs:domain pm:Person ;
    rdfs:range xsd:string .

pm:slackUserId
    a owl:DatatypeProperty ;
    rdfs:label "Slack 사용자 ID"@ko ;
    rdfs:comment "맥락 인식 알림을 Slack으로 발송할 때 사용됩니다."@ko ;
    rdfs:domain pm:Person ;
    rdfs:range xsd:string .

pm:githubLogin
    a owl:DatatypeProperty ;
    rdfs:label "GitHub 로그인 ID"@ko ;
    rdfs:comment "GitCommitEvent와 Person을 연결하는 키입니다."@ko ;
    rdfs:domain pm:Person ;
    rdfs:range xsd:string .

pm:figmaUserId
    a owl:DatatypeProperty ;
    rdfs:label "Figma 사용자 ID"@ko ;
    rdfs:comment "DesignEvent와 Person을 연결하는 키입니다."@ko ;
    rdfs:domain pm:Person ;
    rdfs:range xsd:string .

pm:notionUserId
    a owl:DatatypeProperty ;
    rdfs:label "Notion 사용자 ID"@ko ;
    rdfs:domain pm:Person ;
    rdfs:range xsd:string .

pm:availabilityScore
    a owl:DatatypeProperty ;
    rdfs:label "가용성 점수"@ko ;
    rdfs:comment """
        현재 담당 Task의 부하를 기반으로 0.0~1.0 사이로 산출됩니다.
        1.0에 가까울수록 새 프로젝트 투입 가능 여력이 큽니다.
        WBS ProgressSignal을 통해 실시간으로 갱신됩니다.
    """@ko ;
    rdfs:domain pm:Person ;
    rdfs:range xsd:decimal .

# ──────────────────────────────────────────────────────────────────
#  Organization (조직)
#  팀, 부서, 회사 등 조직 단위를 표현합니다.
# ──────────────────────────────────────────────────────────────────
pm:Organization
    a owl:Class ;
    rdfs:label "조직"@ko , "Organization"@en ;
    rdfs:comment "Person이 소속되고, Project를 수행하는 조직 단위입니다."@ko .

pm:orgId
    a owl:DatatypeProperty ;
    rdfs:label "조직 식별자"@ko ;
    rdfs:domain pm:Organization ;
    rdfs:range xsd:string .

pm:orgName
    a owl:DatatypeProperty ;
    rdfs:label "조직 이름"@ko ;
    rdfs:domain pm:Organization ;
    rdfs:range xsd:string .

pm:belongsTo
    a owl:ObjectProperty ;
    rdfs:label "소속"@ko ;
    rdfs:comment "Person이 어떤 Organization에 속하는지를 나타냅니다."@ko ;
    rdfs:domain pm:Person ;
    rdfs:range pm:Organization .

# ──────────────────────────────────────────────────────────────────
#  Skill (역량 / 기술 스택)
#  실무자가 보유한 기술·도메인 지식·소프트 스킬을 표현합니다.
#  CompetencySignal이 누적될수록 proficiencyLevel이 자동 갱신됩니다.
# ──────────────────────────────────────────────────────────────────
pm:Skill
    a owl:Class ;
    rdfs:label "역량"@ko , "Skill"@en ;
    rdfs:comment """
        기술 스택(React, TypeScript, Python 등), 도메인 지식(핀테크, 헬스케어 등),
        소프트 스킬(커뮤니케이션, 리더십 등)을 포함합니다.
        업무 로그에서 자동 추출된 CompetencySignal을 통해 숙련도가 점진적으로 업데이트됩니다.
    """@ko .

pm:skillId
    a owl:DatatypeProperty ;
    rdfs:label "역량 식별자"@ko ;
    rdfs:domain pm:Skill ;
    rdfs:range xsd:string .

pm:skillName
    a owl:DatatypeProperty ;
    rdfs:label "역량 이름"@ko ;
    rdfs:comment "예: 'React', 'TypeScript', '핀테크 도메인', 'UI 기획'"@ko ;
    rdfs:domain pm:Skill ;
    rdfs:range xsd:string .

pm:skillCategory
    a owl:DatatypeProperty ;
    rdfs:label "역량 분류"@ko ;
    rdfs:comment "TECHNICAL, DOMAIN, SOFT_SKILL 중 하나입니다."@ko ;
    rdfs:domain pm:Skill ;
    rdfs:range xsd:string .

# Person ↔ Skill 관계
pm:hasSkill
    a owl:ObjectProperty ;
    rdfs:label "보유 역량"@ko ;
    rdfs:comment "Person이 어떤 Skill을 보유하는지를 나타냅니다."@ko ;
    rdfs:domain pm:Person ;
    rdfs:range pm:Skill .

pm:proficiencyLevel
    a owl:DatatypeProperty ;
    rdfs:label "숙련도"@ko ;
    rdfs:comment """
        0.0~1.0 사이의 숙련도 점수입니다.
        CompetencySignal이 누적됨에 따라 자동 계산됩니다.
        인력 추천 시 requiredSkill과 매칭하는 핵심 값입니다.
    """@ko ;
    rdfs:domain pm:Skill ;
    rdfs:range xsd:decimal .

pm:skillEvidenceCount
    a owl:DatatypeProperty ;
    rdfs:label "역량 증거 수"@ko ;
    rdfs:comment "이 역량을 뒷받침하는 CompetencySignal의 누적 건수입니다."@ko ;
    rdfs:domain pm:Skill ;
    rdfs:range xsd:integer .

# ──────────────────────────────────────────────────────────────────
#  Project (프로젝트)
#  수행 중이거나 예정된 프로젝트를 표현합니다.
#  도메인, 기술 스택, 난이도, WBS 등이 포함됩니다.
# ──────────────────────────────────────────────────────────────────
pm:Project
    a owl:Class ;
    rdfs:label "프로젝트"@ko , "Project"@en ;
    rdfs:comment """
        수행 중이거나 새로 등록된 프로젝트를 나타냅니다.
        인력 추천 시 이 클래스의 domain, techStack, difficulty를 기준으로
        적합한 Person을 탐색합니다.
    """@ko .

pm:projectId
    a owl:DatatypeProperty ;
    rdfs:label "프로젝트 식별자"@ko ;
    rdfs:domain pm:Project ;
    rdfs:range xsd:string .

pm:projectName
    a owl:DatatypeProperty ;
    rdfs:label "프로젝트 이름"@ko ;
    rdfs:domain pm:Project ;
    rdfs:range xsd:string .

pm:projectDomain
    a owl:DatatypeProperty ;
    rdfs:label "도메인"@ko ;
    rdfs:comment "예: '핀테크', '헬스케어', '이커머스', 'SaaS' 등"@ko ;
    rdfs:domain pm:Project ;
    rdfs:range xsd:string .

pm:techStack
    a owl:DatatypeProperty ;
    rdfs:label "기술 스택"@ko ;
    rdfs:comment "예: 'React', 'Node.js', 'PostgreSQL' (다중 값 가능)"@ko ;
    rdfs:domain pm:Project ;
    rdfs:range xsd:string .

pm:difficultyLevel
    a owl:DatatypeProperty ;
    rdfs:label "난이도"@ko ;
    rdfs:comment "LOW, MEDIUM, HIGH, CRITICAL 중 하나입니다."@ko ;
    rdfs:domain pm:Project ;
    rdfs:range xsd:string .

pm:projectStatus
    a owl:DatatypeProperty ;
    rdfs:label "프로젝트 상태"@ko ;
    rdfs:comment "PLANNING, ACTIVE, ON_HOLD, COMPLETED 중 하나입니다."@ko ;
    rdfs:domain pm:Project ;
    rdfs:range xsd:string .

pm:startDate
    a owl:DatatypeProperty ;
    rdfs:label "시작일"@ko ;
    rdfs:domain pm:Project ;
    rdfs:range xsd:date .

pm:endDate
    a owl:DatatypeProperty ;
    rdfs:label "종료일"@ko ;
    rdfs:domain pm:Project ;
    rdfs:range xsd:date .

pm:participatesIn
    a owl:ObjectProperty ;
    rdfs:label "참여 프로젝트"@ko ;
    rdfs:comment "Person이 어떤 Project에 참여하는지를 나타냅니다."@ko ;
    rdfs:domain pm:Person ;
    rdfs:range pm:Project .

pm:hasTask
    a owl:ObjectProperty ;
    rdfs:label "포함 업무"@ko ;
    rdfs:comment "Project가 어떤 Task들을 포함하는지를 나타냅니다."@ko ;
    rdfs:domain pm:Project ;
    rdfs:range pm:Task .

pm:ownedBy
    a owl:ObjectProperty ;
    rdfs:label "소유 조직"@ko ;
    rdfs:domain pm:Project ;
    rdfs:range pm:Organization .

# ──────────────────────────────────────────────────────────────────
#  Task (업무 단위 / WBS 항목)
#  WBS의 개별 항목을 표현합니다.
#  업무 툴 로그(커밋, Figma 프레임 완성 등)를 통해
#  progress(%)가 자동으로 갱신됩니다.
# ──────────────────────────────────────────────────────────────────
pm:Task
    a owl:Class ;
    rdfs:label "업무"@ko , "Task"@en ;
    rdfs:comment """
        WBS의 최소 실행 단위입니다.
        GitCommitEvent, DesignEvent 등의 WorkEvent가 이 Task의 progress를
        자동으로 업데이트합니다.
        화면 변경 알림 시 'Frame → Task → Person' 트리플 체인의 중간 노드입니다.
    """@ko .

pm:taskId
    a owl:DatatypeProperty ;
    rdfs:label "업무 식별자"@ko ;
    rdfs:domain pm:Task ;
    rdfs:range xsd:string .

pm:taskName
    a owl:DatatypeProperty ;
    rdfs:label "업무 이름"@ko ;
    rdfs:domain pm:Task ;
    rdfs:range xsd:string .

pm:wbsCode
    a owl:DatatypeProperty ;
    rdfs:label "WBS 코드"@ko ;
    rdfs:comment "예: '1.2.3' — 계층적 WBS 구조를 표현합니다."@ko ;
    rdfs:domain pm:Task ;
    rdfs:range xsd:string .

pm:taskStatus
    a owl:DatatypeProperty ;
    rdfs:label "업무 상태"@ko ;
    rdfs:comment "TODO, IN_PROGRESS, REVIEW, DONE 중 하나입니다."@ko ;
    rdfs:domain pm:Task ;
    rdfs:range xsd:string .

pm:progressPercent
    a owl:DatatypeProperty ;
    rdfs:label "진척률"@ko ;
    rdfs:comment """
        0~100 사이의 정수입니다.
        ProgressSignal이 생성될 때마다 추론 엔진이 이 값을 자동 갱신합니다.
        수기 입력 없이 툴 로그만으로 업데이트되는 것이 핵심 차별점입니다.
    """@ko ;
    rdfs:domain pm:Task ;
    rdfs:range xsd:integer .

pm:plannedHours
    a owl:DatatypeProperty ;
    rdfs:label "계획 공수"@ko ;
    rdfs:domain pm:Task ;
    rdfs:range xsd:decimal .

pm:actualHours
    a owl:DatatypeProperty ;
    rdfs:label "실제 공수"@ko ;
    rdfs:comment "WorkEvent의 타임스탬프를 기반으로 자동 누적됩니다."@ko ;
    rdfs:domain pm:Task ;
    rdfs:range xsd:decimal .

pm:dueDate
    a owl:DatatypeProperty ;
    rdfs:label "마감일"@ko ;
    rdfs:domain pm:Task ;
    rdfs:range xsd:date .

pm:assignedTo
    a owl:ObjectProperty ;
    rdfs:label "담당자"@ko ;
    rdfs:comment """
        Task의 담당 Person을 나타냅니다.
        화면 변경 알림 흐름에서
        'Frame → implementedBy → Task → assignedTo → Person'
        트리플 체인을 따라 알림 수신자를 자동 특정합니다.
    """@ko ;
    rdfs:domain pm:Task ;
    rdfs:range pm:Person .

pm:requiresSkill
    a owl:ObjectProperty ;
    rdfs:label "필요 역량"@ko ;
    rdfs:comment "이 Task를 수행하는 데 필요한 Skill을 나타냅니다."@ko ;
    rdfs:domain pm:Task ;
    rdfs:range pm:Skill .

pm:hasSourceFile
    a owl:DatatypeProperty ;
    rdfs:label "소스 파일 경로"@ko ;
    rdfs:comment """
        이 Task와 연결된 소스코드 파일 경로입니다.
        예: 'src/components/auth/LoginForm.tsx'
        화면 변경 알림 시 개발자에게 '수정이 필요한 파일'로 전달됩니다.
    """@ko ;
    rdfs:domain pm:Task ;
    rdfs:range xsd:string .

pm:parentTask
    a owl:ObjectProperty ;
    rdfs:label "상위 업무"@ko ;
    rdfs:comment "WBS 계층 구조를 표현합니다. 하위 Task가 상위 Task를 참조합니다."@ko ;
    rdfs:domain pm:Task ;
    rdfs:range pm:Task .

pm:dependsOn
    a owl:ObjectProperty ;
    rdfs:label "선행 업무"@ko ;
    rdfs:comment "이 Task가 시작되기 전에 완료되어야 하는 선행 Task입니다."@ko ;
    rdfs:domain pm:Task ;
    rdfs:range pm:Task .

# ──────────────────────────────────────────────────────────────────
#  DesignComponent (Figma 컴포넌트 / 화면 단위)
#  Figma의 Frame 또는 Component를 온톨로지 노드로 표현합니다.
#  화면 변경 알림의 출발점입니다.
# ──────────────────────────────────────────────────────────────────
pm:DesignComponent
    a owl:Class ;
    rdfs:label "디자인 컴포넌트"@ko , "DesignComponent"@en ;
    rdfs:comment """
        Figma의 Frame, Component, Section 등을 나타냅니다.
        'implementedBy' 관계를 통해 Task와 연결되며,
        기획자가 이 컴포넌트를 수정하면
        연결된 Task의 담당 개발자에게 자동 알림이 발송됩니다.
    """@ko .

pm:figmaFrameId
    a owl:DatatypeProperty ;
    rdfs:label "Figma 프레임 ID"@ko ;
    rdfs:domain pm:DesignComponent ;
    rdfs:range xsd:string .

pm:componentName
    a owl:DatatypeProperty ;
    rdfs:label "컴포넌트 이름"@ko ;
    rdfs:comment "예: 'LoginScreen', 'PaymentModal', 'NavBar'"@ko ;
    rdfs:domain pm:DesignComponent ;
    rdfs:range xsd:string .

pm:figmaFileUrl
    a owl:DatatypeProperty ;
    rdfs:label "Figma 파일 URL"@ko ;
    rdfs:domain pm:DesignComponent ;
    rdfs:range xsd:anyURI .

pm:implementedBy
    a owl:ObjectProperty ;
    rdfs:label "구현 업무"@ko ;
    rdfs:comment """
        DesignComponent(Figma 화면)가 어떤 Task로 구현되는지를 나타냅니다.
        이 관계가 화면 변경 → 개발자 알림 자동화의 핵심 연결고리입니다.
        프로젝트 킥오프 시 PM 또는 기획자가 수동으로 매핑하거나,
        Figma 컴포넌트 이름과 GitHub 파일명의 유사도를 통해 반자동 추론됩니다.
    """@ko ;
    rdfs:domain pm:DesignComponent ;
    rdfs:range pm:Task .


# ══════════════════════════════════════════════════════════════════
#  LAYER 2 — 수집 레이어: WorkEvent 클래스 계층
#
#  Figma, GitHub, Notion, Slack 등 실무 툴의 API 로그를
#  온톨로지 인스턴스로 정규화합니다.
#  모든 이벤트는 WorkEvent를 상속하며, 소스별로 서브클래스를 가집니다.
# ══════════════════════════════════════════════════════════════════

pm:WorkEvent
    a owl:Class ;
    rdfs:label "업무 이벤트"@ko , "WorkEvent"@en ;
    rdfs:comment """
        실무 도구에서 발생한 모든 활동 로그의 공통 상위 클래스입니다.
        각 도구의 webhook/API를 통해 수집된 후 이 클래스의 인스턴스로 정규화됩니다.
        Semantic Interpreter가 이 인스턴스를 입력으로 받아 SemanticUnit을 생성합니다.
    """@ko .

pm:eventId
    a owl:DatatypeProperty ;
    rdfs:label "이벤트 식별자"@ko ;
    rdfs:domain pm:WorkEvent ;
    rdfs:range xsd:string .

pm:eventSource
    a owl:DatatypeProperty ;
    rdfs:label "이벤트 출처"@ko ;
    rdfs:comment "GITHUB, FIGMA, NOTION, SLACK, JIRA, LINEAR 등"@ko ;
    rdfs:domain pm:WorkEvent ;
    rdfs:range xsd:string .

pm:eventTimestamp
    a owl:DatatypeProperty ;
    rdfs:label "발생 시각"@ko ;
    rdfs:domain pm:WorkEvent ;
    rdfs:range xsd:dateTime .

pm:rawPayload
    a owl:DatatypeProperty ;
    rdfs:label "원본 페이로드"@ko ;
    rdfs:comment "API로부터 수신한 원본 JSON 문자열을 보존합니다. 추후 재분석에 활용됩니다."@ko ;
    rdfs:domain pm:WorkEvent ;
    rdfs:range xsd:string .

pm:performedBy
    a owl:ObjectProperty ;
    rdfs:label "수행자"@ko ;
    rdfs:comment "이 이벤트를 발생시킨 Person입니다."@ko ;
    rdfs:domain pm:WorkEvent ;
    rdfs:range pm:Person .

pm:relatedToTask
    a owl:ObjectProperty ;
    rdfs:label "관련 업무"@ko ;
    rdfs:comment """
        이 이벤트가 어떤 Task와 연결되는지를 나타냅니다.
        브랜치 이름, Notion 페이지 제목, Figma 프레임 ID 등을 통해
        자동 매핑하거나 추론 엔진이 연결합니다.
    """@ko ;
    rdfs:domain pm:WorkEvent ;
    rdfs:range pm:Task .

# ──────────────────────────────────────────────────────────────────
#  GitCommitEvent — GitHub 커밋 이벤트
# ──────────────────────────────────────────────────────────────────
pm:GitCommitEvent
    a owl:Class ;
    rdfs:subClassOf pm:WorkEvent ;
    rdfs:label "Git 커밋 이벤트"@ko ;
    rdfs:comment """
        GitHub(또는 GitLab) 커밋, PR 생성·머지, 이슈 등록 등을 표현합니다.
        커밋 메시지와 변경 파일 목록(diff)을 분석하여
        ProgressSignal 또는 IssueSignal로 해석됩니다.
    """@ko .

pm:commitHash
    a owl:DatatypeProperty ;
    rdfs:label "커밋 해시"@ko ;
    rdfs:domain pm:GitCommitEvent ;
    rdfs:range xsd:string .

pm:repoName
    a owl:DatatypeProperty ;
    rdfs:label "저장소 이름"@ko ;
    rdfs:domain pm:GitCommitEvent ;
    rdfs:range xsd:string .

pm:branchName
    a owl:DatatypeProperty ;
    rdfs:label "브랜치 이름"@ko ;
    rdfs:comment "브랜치 이름 패턴(feature/task-123)으로 Task를 자동 매핑할 수 있습니다."@ko ;
    rdfs:domain pm:GitCommitEvent ;
    rdfs:range xsd:string .

pm:commitMessage
    a owl:DatatypeProperty ;
    rdfs:label "커밋 메시지"@ko ;
    rdfs:domain pm:GitCommitEvent ;
    rdfs:range xsd:string .

pm:changedFilePaths
    a owl:DatatypeProperty ;
    rdfs:label "변경 파일 경로 목록"@ko ;
    rdfs:comment "변경된 소스 파일 경로 목록(JSON 배열 문자열). Task.hasSourceFile과 매핑합니다."@ko ;
    rdfs:domain pm:GitCommitEvent ;
    rdfs:range xsd:string .

pm:linesAdded
    a owl:DatatypeProperty ;
    rdfs:label "추가 라인 수"@ko ;
    rdfs:domain pm:GitCommitEvent ;
    rdfs:range xsd:integer .

pm:linesDeleted
    a owl:DatatypeProperty ;
    rdfs:label "삭제 라인 수"@ko ;
    rdfs:domain pm:GitCommitEvent ;
    rdfs:range xsd:integer .

pm:gitEventType
    a owl:DatatypeProperty ;
    rdfs:label "Git 이벤트 유형"@ko ;
    rdfs:comment "COMMIT, PR_OPEN, PR_MERGE, PR_REVIEW, ISSUE_OPEN, ISSUE_CLOSE 중 하나"@ko ;
    rdfs:domain pm:GitCommitEvent ;
    rdfs:range xsd:string .

# ──────────────────────────────────────────────────────────────────
#  DesignEvent — Figma 디자인 변경 이벤트
# ──────────────────────────────────────────────────────────────────
pm:DesignEvent
    a owl:Class ;
    rdfs:subClassOf pm:WorkEvent ;
    rdfs:label "디자인 이벤트"@ko ;
    rdfs:comment """
        Figma의 Frame 수정, Comment 등록, Component 생성/삭제 등을 표현합니다.
        이 이벤트가 발생하면 관련 DesignComponent를 조회하고,
        implementedBy → Task → assignedTo → Person 체인을 따라
        담당 개발자에게 맥락 알림을 자동 발송합니다.
    """@ko .

pm:figmaEventFrameId
    a owl:DatatypeProperty ;
    rdfs:label "변경된 Frame ID"@ko ;
    rdfs:domain pm:DesignEvent ;
    rdfs:range xsd:string .

pm:designChangeType
    a owl:DatatypeProperty ;
    rdfs:label "변경 유형"@ko ;
    rdfs:comment "FRAME_MODIFIED, COMPONENT_ADDED, COMPONENT_DELETED, STYLE_CHANGED, COMMENT_ADDED"@ko ;
    rdfs:domain pm:DesignEvent ;
    rdfs:range xsd:string .

pm:affectedComponents
    a owl:DatatypeProperty ;
    rdfs:label "영향받은 컴포넌트 목록"@ko ;
    rdfs:comment "변경으로 인해 영향받은 컴포넌트 ID 목록(JSON 배열 문자열)"@ko ;
    rdfs:domain pm:DesignEvent ;
    rdfs:range xsd:string .

pm:designDiffSummary
    a owl:DatatypeProperty ;
    rdfs:label "변경 요약"@ko ;
    rdfs:comment "LLM이 생성한 변경 내용 요약 텍스트. 알림 메시지에 포함됩니다."@ko ;
    rdfs:domain pm:DesignEvent ;
    rdfs:range xsd:string .

pm:relatedToComponent
    a owl:ObjectProperty ;
    rdfs:label "관련 디자인 컴포넌트"@ko ;
    rdfs:domain pm:DesignEvent ;
    rdfs:range pm:DesignComponent .

# ──────────────────────────────────────────────────────────────────
#  DocumentEvent — Notion 문서 편집 이벤트
# ──────────────────────────────────────────────────────────────────
pm:DocumentEvent
    a owl:Class ;
    rdfs:subClassOf pm:WorkEvent ;
    rdfs:label "문서 이벤트"@ko ;
    rdfs:comment """
        Notion의 페이지 편집, 데이터베이스 항목 추가/수정,
        코멘트 작성 등을 표현합니다.
        기획 문서 업데이트 → Task 연결 → 진척도 반영에 활용됩니다.
    """@ko .

pm:notionPageId
    a owl:DatatypeProperty ;
    rdfs:label "Notion 페이지 ID"@ko ;
    rdfs:domain pm:DocumentEvent ;
    rdfs:range xsd:string .

pm:documentEventType
    a owl:DatatypeProperty ;
    rdfs:label "문서 이벤트 유형"@ko ;
    rdfs:comment "PAGE_EDITED, PAGE_CREATED, DATABASE_ITEM_ADDED, DATABASE_ITEM_UPDATED, COMMENT_ADDED"@ko ;
    rdfs:domain pm:DocumentEvent ;
    rdfs:range xsd:string .

pm:editDelta
    a owl:DatatypeProperty ;
    rdfs:label "편집 내용 요약"@ko ;
    rdfs:comment "변경된 텍스트 블록의 요약. LLM이 업무 의미를 해석하는 데 사용됩니다."@ko ;
    rdfs:domain pm:DocumentEvent ;
    rdfs:range xsd:string .

# ──────────────────────────────────────────────────────────────────
#  MessageEvent — Slack 메시지/반응 이벤트
# ──────────────────────────────────────────────────────────────────
pm:MessageEvent
    a owl:Class ;
    rdfs:subClassOf pm:WorkEvent ;
    rdfs:label "메시지 이벤트"@ko ;
    rdfs:comment """
        Slack의 메시지 전송, 이모지 반응, 멘션 등을 표현합니다.
        메시지 내용을 LLM이 분석하여 이슈 보고, 완료 공지,
        협업 요청 등의 의미를 추출합니다.
        CollaborationSignal의 주요 원천입니다.
    """@ko .

pm:slackChannel
    a owl:DatatypeProperty ;
    rdfs:label "채널"@ko ;
    rdfs:domain pm:MessageEvent ;
    rdfs:range xsd:string .

pm:messageText
    a owl:DatatypeProperty ;
    rdfs:label "메시지 내용"@ko ;
    rdfs:domain pm:MessageEvent ;
    rdfs:range xsd:string .

pm:messageIntent
    a owl:DatatypeProperty ;
    rdfs:label "메시지 의도"@ko ;
    rdfs:comment """
        LLM이 분류한 의도 유형입니다.
        ISSUE_REPORT, COMPLETION_NOTICE, HELP_REQUEST,
        REVIEW_REQUEST, BLOCKER_REPORT 등이 올 수 있습니다.
    """@ko ;
    rdfs:domain pm:MessageEvent ;
    rdfs:range xsd:string .

pm:sentimentScore
    a owl:DatatypeProperty ;
    rdfs:label "감정 점수"@ko ;
    rdfs:comment "-1.0(매우 부정) ~ 1.0(매우 긍정). 팀 분위기 모니터링에 활용됩니다."@ko ;
    rdfs:domain pm:MessageEvent ;
    rdfs:range xsd:decimal .

pm:mentionedPersons
    a owl:DatatypeProperty ;
    rdfs:label "멘션된 구성원 ID 목록"@ko ;
    rdfs:comment "CollaborationSignal 생성 시 협업 쌍을 특정하는 데 사용됩니다."@ko ;
    rdfs:domain pm:MessageEvent ;
    rdfs:range xsd:string .


# ══════════════════════════════════════════════════════════════════
#  LAYER 3 — 의미 해석 레이어: SemanticUnit 클래스 계층
#
#  LLM + 온톨로지 컨텍스트가 WorkEvent를 분석하여
#  '업무 진척', '이슈 발생', '역량 발휘', '협업' 등의 의미 단위로 변환합니다.
#  이 레이어가 단순 로그를 지식으로 승격시키는 핵심입니다.
# ══════════════════════════════════════════════════════════════════

pm:SemanticUnit
    a owl:Class ;
    rdfs:label "의미 단위"@ko , "SemanticUnit"@en ;
    rdfs:comment """
        WorkEvent를 해석한 결과물입니다.
        '이 커밋은 LoginPage Task를 35% 진척시켰다',
        '이 Slack 메시지는 결제 모듈의 블로커 이슈다'와 같이
        업무적 의미가 부여된 단위입니다.
        Knowledge Graph에 트리플로 저장되어 추론의 기반이 됩니다.
    """@ko .

pm:semanticId
    a owl:DatatypeProperty ;
    rdfs:label "의미 단위 식별자"@ko ;
    rdfs:domain pm:SemanticUnit ;
    rdfs:range xsd:string .

pm:meaning
    a owl:DatatypeProperty ;
    rdfs:label "해석된 의미"@ko ;
    rdfs:comment "LLM이 생성한 자연어 설명. 예: '로그인 화면 UI 구현 작업 40% 진척'"@ko ;
    rdfs:domain pm:SemanticUnit ;
    rdfs:range xsd:string .

pm:confidenceScore
    a owl:DatatypeProperty ;
    rdfs:label "신뢰도"@ko ;
    rdfs:comment """
        LLM의 해석 신뢰도(0.0~1.0). 낮을 경우 담당자 확인 요청을 트리거합니다.
        SemanticUnit(이벤트 해석)과 RFP(제안요청서 자동 분석) 양쪽에서 사용합니다.
    """@ko ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( pm:SemanticUnit pm:RFP ) ] ;
    rdfs:range xsd:decimal .

pm:derivedFromEvent
    a owl:ObjectProperty ;
    rdfs:label "원천 이벤트"@ko ;
    rdfs:comment "이 SemanticUnit을 생성한 WorkEvent입니다."@ko ;
    rdfs:domain pm:SemanticUnit ;
    rdfs:range pm:WorkEvent .

pm:interpretedAt
    a owl:DatatypeProperty ;
    rdfs:label "해석 시각"@ko ;
    rdfs:domain pm:SemanticUnit ;
    rdfs:range xsd:dateTime .

# ──────────────────────────────────────────────────────────────────
#  ProgressSignal — 업무 진척 신호
#  GitCommitEvent, DesignEvent 등에서 추출됩니다.
# ──────────────────────────────────────────────────────────────────
pm:ProgressSignal
    a owl:Class ;
    rdfs:subClassOf pm:SemanticUnit ;
    rdfs:label "진척 신호"@ko ;
    rdfs:comment """
        특정 Task의 진척이 발생했음을 나타냅니다.
        추론 엔진은 이 신호를 수신하면 연결된 Task.progressPercent를 자동 갱신합니다.
        수기 WBS 업데이트를 완전히 대체하는 핵심 신호입니다.
    """@ko .

pm:progressDelta
    a owl:DatatypeProperty ;
    rdfs:label "진척 증분"@ko ;
    rdfs:comment "이번 이벤트로 인해 Task 진척률이 몇 % 증가했는지를 나타냅니다."@ko ;
    rdfs:domain pm:ProgressSignal ;
    rdfs:range xsd:integer .

pm:signalRefTask
    a owl:ObjectProperty ;
    rdfs:label "참조 업무"@ko ;
    rdfs:comment "이 진척 신호가 가리키는 Task입니다."@ko ;
    rdfs:domain pm:ProgressSignal ;
    rdfs:range pm:Task .

# ──────────────────────────────────────────────────────────────────
#  IssueSignal — 이슈 발생 신호
#  Slack 블로커 메시지, GitHub 이슈 등에서 추출됩니다.
# ──────────────────────────────────────────────────────────────────
pm:IssueSignal
    a owl:Class ;
    rdfs:subClassOf pm:SemanticUnit ;
    rdfs:label "이슈 신호"@ko ;
    rdfs:comment """
        업무 진행을 방해하는 이슈, 버그, 리스크가 감지되었음을 나타냅니다.
        심각도에 따라 관련 Task 담당자와 PM에게 맥락 알림이 발송됩니다.
        영향받는 Task 목록을 포함하여 파급 범위를 가시화합니다.
    """@ko .

pm:issueSeverity
    a owl:DatatypeProperty ;
    rdfs:label "심각도"@ko ;
    rdfs:comment "LOW, MEDIUM, HIGH, CRITICAL 중 하나입니다."@ko ;
    rdfs:domain pm:IssueSignal ;
    rdfs:range xsd:string .

pm:issueType
    a owl:DatatypeProperty ;
    rdfs:label "이슈 유형"@ko ;
    rdfs:comment "BLOCKER, BUG, RISK, DEPENDENCY_DELAY, SCOPE_CHANGE 등"@ko ;
    rdfs:domain pm:IssueSignal ;
    rdfs:range xsd:string .

pm:affectedTasks
    a owl:ObjectProperty ;
    rdfs:label "영향받는 업무"@ko ;
    rdfs:comment "이 이슈로 인해 지연·차단될 수 있는 Task 목록입니다."@ko ;
    rdfs:domain pm:IssueSignal ;
    rdfs:range pm:Task .

pm:issueResolved
    a owl:DatatypeProperty ;
    rdfs:label "해결 여부"@ko ;
    rdfs:domain pm:IssueSignal ;
    rdfs:range xsd:boolean .

# ──────────────────────────────────────────────────────────────────
#  CompetencySignal — 역량 발휘 신호
#  커밋, 디자인 완성, 문서 작성 등 모든 생산적 활동에서 추출됩니다.
# ──────────────────────────────────────────────────────────────────
pm:CompetencySignal
    a owl:Class ;
    rdfs:subClassOf pm:SemanticUnit ;
    rdfs:label "역량 신호"@ko ;
    rdfs:comment """
        실무자가 특정 Skill을 발휘했음을 나타냅니다.
        시간이 쌓일수록 Person.hasSkill → Skill.proficiencyLevel이
        자동으로 상승하여 커리어 그래프의 데이터 기반이 됩니다.
        인력 추천 시 역량 점수 계산에 직접 사용됩니다.
    """@ko .

pm:demonstratedSkill
    a owl:ObjectProperty ;
    rdfs:label "발휘된 역량"@ko ;
    rdfs:domain pm:CompetencySignal ;
    rdfs:range pm:Skill .

pm:competencyContext
    a owl:DatatypeProperty ;
    rdfs:label "역량 발휘 맥락"@ko ;
    rdfs:comment "예: 'React 컴포넌트 최적화 코드 작성', 'TypeScript 타입 설계'"@ko ;
    rdfs:domain pm:CompetencySignal ;
    rdfs:range xsd:string .

pm:competencyStrength
    a owl:DatatypeProperty ;
    rdfs:label "발휘 강도"@ko ;
    rdfs:comment "0.0~1.0. 단순 사용(낮음)인지 고난도 적용(높음)인지를 나타냅니다."@ko ;
    rdfs:domain pm:CompetencySignal ;
    rdfs:range xsd:decimal .

# ──────────────────────────────────────────────────────────────────
#  CollaborationSignal — 협업 상호작용 신호
#  Slack 멘션, PR 리뷰, 공동 편집 등에서 추출됩니다.
# ──────────────────────────────────────────────────────────────────
pm:CollaborationSignal
    a owl:Class ;
    rdfs:subClassOf pm:SemanticUnit ;
    rdfs:label "협업 신호"@ko ;
    rdfs:comment """
        두 Person 사이의 협업 상호작용이 발생했음을 나타냅니다.
        누적될수록 'collaboratedWith' 관계의 synergyScore가 갱신되어
        인력 추천 시 '함께 일하면 효과적인 조합'을 계산하는 데 활용됩니다.
    """@ko .

pm:collaboratorA
    a owl:ObjectProperty ;
    rdfs:label "협업자 A"@ko ;
    rdfs:domain pm:CollaborationSignal ;
    rdfs:range pm:Person .

pm:collaboratorB
    a owl:ObjectProperty ;
    rdfs:label "협업자 B"@ko ;
    rdfs:domain pm:CollaborationSignal ;
    rdfs:range pm:Person .

pm:collaborationType
    a owl:DatatypeProperty ;
    rdfs:label "협업 유형"@ko ;
    rdfs:comment "PR_REVIEW, SLACK_MENTION, FIGMA_COMMENT, NOTION_CO_EDIT 등"@ko ;
    rdfs:domain pm:CollaborationSignal ;
    rdfs:range xsd:string .

pm:interactionQuality
    a owl:DatatypeProperty ;
    rdfs:label "상호작용 품질"@ko ;
    rdfs:comment "0.0~1.0. 단순 반응(낮음)인지 깊은 기술 논의(높음)인지를 나타냅니다."@ko ;
    rdfs:domain pm:CollaborationSignal ;
    rdfs:range xsd:decimal .

# Person 간 협업 관계 (누적 집계)
pm:collaboratedWith
    a owl:ObjectProperty , owl:SymmetricProperty ;
    rdfs:label "협업 관계"@ko ;
    rdfs:comment """
        두 Person 사이의 누적 협업 관계입니다.
        SymmetricProperty로 선언되어 A→B 방향만 저장해도 B→A가 자동 추론됩니다.
        synergyScore와 collaborationCount가 서브프로퍼티로 연결됩니다.
    """@ko ;
    rdfs:domain pm:Person ;
    rdfs:range pm:Person .

pm:synergyScore
    a owl:DatatypeProperty ;
    rdfs:label "시너지 점수"@ko ;
    rdfs:comment """
        두 Person 간 협업 효율성을 나타내는 점수(0.0~1.0)입니다.
        CollaborationSignal 누적 + 상호작용 품질 + 공동 작업 성공률로 계산됩니다.
        인력 추천 시 '이 팀 조합이 효과적인가'를 판단하는 핵심 지표입니다.
    """@ko ;
    rdfs:domain pm:Person ;
    rdfs:range xsd:decimal .

pm:collaborationCount
    a owl:DatatypeProperty ;
    rdfs:label "협업 횟수"@ko ;
    rdfs:domain pm:Person ;
    rdfs:range xsd:integer .


# ══════════════════════════════════════════════════════════════════
#  LAYER 4 — 서비스 레이어: 산출물 클래스
#
#  Knowledge Graph의 추론 결과물로 생성되는 서비스 객체들입니다.
#  대시보드, 알림, 보고서, 인력 추천이 이 레이어에 속합니다.
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
#  Alert — 맥락 인식 알림
#  단순 변경 알림이 아닌, '무엇을 왜 수정해야 하는지'를 담은 알림입니다.
# ──────────────────────────────────────────────────────────────────
pm:Alert
    a owl:Class ;
    rdfs:label "알림"@ko , "Alert"@en ;
    rdfs:comment """
        맥락이 포함된 지능형 알림입니다.
        '기획자가 LoginScreen을 수정했으니 src/auth/LoginForm.tsx를 확인하세요'와 같이
        수신자가 즉시 행동할 수 있는 정보를 포함합니다.
    """@ko .

pm:alertId
    a owl:DatatypeProperty ;
    rdfs:label "알림 식별자"@ko ;
    rdfs:domain pm:Alert ;
    rdfs:range xsd:string .

pm:alertType
    a owl:DatatypeProperty ;
    rdfs:label "알림 유형"@ko ;
    rdfs:comment "DESIGN_CHANGED, ISSUE_DETECTED, PROGRESS_BLOCKED, DEADLINE_RISK 등"@ko ;
    rdfs:domain pm:Alert ;
    rdfs:range xsd:string .

pm:alertTitle
    a owl:DatatypeProperty ;
    rdfs:label "알림 제목"@ko ;
    rdfs:domain pm:Alert ;
    rdfs:range xsd:string .

pm:alertBody
    a owl:DatatypeProperty ;
    rdfs:label "알림 본문"@ko ;
    rdfs:comment "변경 내용, 영향 범위, 수정 필요 파일/위치를 포함한 상세 설명"@ko ;
    rdfs:domain pm:Alert ;
    rdfs:range xsd:string .

pm:alertRecipients
    a owl:ObjectProperty ;
    rdfs:label "수신자"@ko ;
    rdfs:domain pm:Alert ;
    rdfs:range pm:Person .

pm:triggeringSignal
    a owl:ObjectProperty ;
    rdfs:label "트리거 신호"@ko ;
    rdfs:comment "이 알림을 발생시킨 SemanticUnit입니다."@ko ;
    rdfs:domain pm:Alert ;
    rdfs:range pm:SemanticUnit .

pm:deliveryChannel
    a owl:DatatypeProperty ;
    rdfs:label "발송 채널"@ko ;
    rdfs:comment "SLACK, EMAIL, IN_APP 등 알림 발송 채널"@ko ;
    rdfs:domain pm:Alert ;
    rdfs:range xsd:string .

pm:alertSentAt
    a owl:DatatypeProperty ;
    rdfs:label "발송 시각"@ko ;
    rdfs:domain pm:Alert ;
    rdfs:range xsd:dateTime .

# ──────────────────────────────────────────────────────────────────
#  WBSSnapshot — WBS 진척 스냅샷
#  특정 시점의 프로젝트 전체 진척 상태를 기록합니다.
# ──────────────────────────────────────────────────────────────────
pm:WBSSnapshot
    a owl:Class ;
    rdfs:label "WBS 스냅샷"@ko , "WBSSnapshot"@en ;
    rdfs:comment """
        프로젝트의 특정 시점 WBS 진척 상태 전체를 캡처한 객체입니다.
        ProgressSignal이 발생할 때마다 Task.progressPercent가 갱신되고,
        주기적으로(또는 이벤트 기반으로) WBSSnapshot이 생성됩니다.
        대시보드와 자동 보고서의 데이터 소스입니다.
    """@ko .

pm:snapshotId
    a owl:DatatypeProperty ;
    rdfs:label "스냅샷 식별자"@ko ;
    rdfs:domain pm:WBSSnapshot ;
    rdfs:range xsd:string .

pm:snapshotProject
    a owl:ObjectProperty ;
    rdfs:label "대상 프로젝트"@ko ;
    rdfs:domain pm:WBSSnapshot ;
    rdfs:range pm:Project .

pm:overallProgress
    a owl:DatatypeProperty ;
    rdfs:label "전체 진척률"@ko ;
    rdfs:comment "프로젝트 전체의 가중 평균 진척률(0~100)"@ko ;
    rdfs:domain pm:WBSSnapshot ;
    rdfs:range xsd:integer .

pm:snapshotCreatedAt
    a owl:DatatypeProperty ;
    rdfs:label "생성 시각"@ko ;
    rdfs:domain pm:WBSSnapshot ;
    rdfs:range xsd:dateTime .

pm:atRiskTaskCount
    a owl:DatatypeProperty ;
    rdfs:label "위험 업무 수"@ko ;
    rdfs:comment "마감일을 초과하거나 IssueSignal이 연결된 Task의 수"@ko ;
    rdfs:domain pm:WBSSnapshot ;
    rdfs:range xsd:integer .

# ──────────────────────────────────────────────────────────────────
#  Report — 자동 생성 보고서
#  주간/월간 보고서 초안을 자동으로 생성합니다.
# ──────────────────────────────────────────────────────────────────
pm:Report
    a owl:Class ;
    rdfs:label "보고서"@ko , "Report"@en ;
    rdfs:comment """
        SemanticUnit 집계를 기반으로 LLM이 자동 생성하는 보고서입니다.
        개인 주간 보고서, 프로젝트 월간 보고서, 역량 성장 리포트 등이 포함됩니다.
        실무자는 초안을 검토하고 보완만 하면 됩니다.
    """@ko .

pm:reportId
    a owl:DatatypeProperty ;
    rdfs:label "보고서 식별자"@ko ;
    rdfs:domain pm:Report ;
    rdfs:range xsd:string .

pm:reportType
    a owl:DatatypeProperty ;
    rdfs:label "보고서 유형"@ko ;
    rdfs:comment "WEEKLY_PERSONAL, MONTHLY_PROJECT, CAREER_GROWTH, TEAM_PERFORMANCE 등"@ko ;
    rdfs:domain pm:Report ;
    rdfs:range xsd:string .

pm:reportPeriodStart
    a owl:DatatypeProperty ;
    rdfs:label "보고 기간 시작"@ko ;
    rdfs:domain pm:Report ;
    rdfs:range xsd:date .

pm:reportPeriodEnd
    a owl:DatatypeProperty ;
    rdfs:label "보고 기간 종료"@ko ;
    rdfs:domain pm:Report ;
    rdfs:range xsd:date .

pm:reportContent
    a owl:DatatypeProperty ;
    rdfs:label "보고서 내용"@ko ;
    rdfs:comment "LLM이 생성한 보고서 초안 텍스트(마크다운 형식)"@ko ;
    rdfs:domain pm:Report ;
    rdfs:range xsd:string .

pm:reportSubject
    a owl:ObjectProperty ;
    rdfs:label "보고 대상"@ko ;
    rdfs:comment "이 보고서가 다루는 Person 또는 Project입니다."@ko ;
    rdfs:domain pm:Report ;
    rdfs:range owl:Thing .

# ──────────────────────────────────────────────────────────────────
#  StaffingRecommendation — 인력 추천 결과
# ──────────────────────────────────────────────────────────────────
pm:StaffingRecommendation
    a owl:Class ;
    rdfs:label "인력 추천"@ko , "StaffingRecommendation"@en ;
    rdfs:comment """
        새 프로젝트 등록 시 생성되는 인력 추천 결과 객체입니다.
        단순 가용성(누가 한가한가)이 아닌
        ① Task 유사도(과거 수행 이력 벡터 매칭)
        ② 역량 점수(CompetencySignal 누적)
        ③ 협업 시너지(CollaborationSignal 그래프)
        세 가지를 조합하여 최적 인력 조합을 제안합니다.
    """@ko .

pm:recommendationId
    a owl:DatatypeProperty ;
    rdfs:label "추천 식별자"@ko ;
    rdfs:domain pm:StaffingRecommendation ;
    rdfs:range xsd:string .

pm:targetProject
    a owl:ObjectProperty ;
    rdfs:label "대상 프로젝트"@ko ;
    rdfs:domain pm:StaffingRecommendation ;
    rdfs:range pm:Project .

pm:recommendedPerson
    a owl:ObjectProperty ;
    rdfs:label "추천 인력"@ko ;
    rdfs:domain pm:StaffingRecommendation ;
    rdfs:range pm:Person .

pm:similarityScore
    a owl:DatatypeProperty ;
    rdfs:label "유사도 점수"@ko ;
    rdfs:comment """
        과거 수행 Task와 신규 프로젝트 간의 벡터 유사도(0.0~1.0)입니다.
        도메인, 기술 스택, 난이도가 유사할수록 높습니다.
    """@ko ;
    rdfs:domain pm:StaffingRecommendation ;
    rdfs:range xsd:decimal .

pm:recommendationRank
    a owl:DatatypeProperty ;
    rdfs:label "추천 순위"@ko ;
    rdfs:domain pm:StaffingRecommendation ;
    rdfs:range xsd:integer .

pm:recommendationReason
    a owl:DatatypeProperty ;
    rdfs:label "추천 근거"@ko ;
    rdfs:comment "LLM이 생성한 자연어 추천 이유. 예: '핀테크 프로젝트 3건 수행, React 숙련도 0.92'"@ko ;
    rdfs:domain pm:StaffingRecommendation ;
    rdfs:range xsd:string .

pm:createdAt
    a owl:DatatypeProperty ;
    rdfs:label "생성 시각"@ko ;
    rdfs:comment "StaffingRecommendation 및 RFP 인스턴스의 생성 시각."@ko ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( pm:StaffingRecommendation pm:RFP ) ] ;
    rdfs:range xsd:dateTime .


# ══════════════════════════════════════════════════════════════════
#  Project / Task 공통 보조 속성
#
#  RFP 자동 분석 결과로 Project/Task 인스턴스가 생성될 때 함께 사용되는
#  속성들입니다. 기존 핵심 속성(progressPercent, plannedHours 등)과는
#  별개로, 기획 단계에서 채워지는 메타데이터에 해당합니다.
# ══════════════════════════════════════════════════════════════════

pm:description
    a owl:DatatypeProperty ;
    rdfs:label "설명"@ko ;
    rdfs:comment "프로젝트의 간단 설명. 제안요청서 요약이나 초기 스코프 정의가 담깁니다."@ko ;
    rdfs:domain pm:Project ;
    rdfs:range xsd:string .

pm:estimatedWeeks
    a owl:DatatypeProperty ;
    rdfs:label "예상 소요 주"@ko ;
    rdfs:comment "Task의 예상 소요 기간(주 단위). RFP 분석 단계에서 산정됩니다."@ko ;
    rdfs:domain pm:Task ;
    rdfs:range xsd:decimal .

pm:deliverable
    a owl:DatatypeProperty ;
    rdfs:label "산출물"@ko ;
    rdfs:comment "Task 완료 시 제출되는 산출물 이름(예: '요구사항 정의서')."@ko ;
    rdfs:domain pm:Task ;
    rdfs:range xsd:string .


# ══════════════════════════════════════════════════════════════════
#  RFP — 제안요청서 (Request for Proposal)
#
#  한글/영문 RFP 파일(PDF/DOCX/HWP)을 업로드하면 시스템이 텍스트를
#  추출하고 LLM으로 프로젝트/WBS/역할을 구조화한 뒤, 사용자 검토를 거쳐
#  온톨로지에 Project + Task 인스턴스로 확정 적재합니다.
#
#  상태 전이: extracted → analyzed → reviewed → confirmed
# ══════════════════════════════════════════════════════════════════

pm:RFP
    a owl:Class ;
    rdfs:label "제안요청서"@ko , "Request for Proposal"@en ;
    rdfs:comment """
        IT 프로젝트 제안요청서(RFP)를 표현합니다.
        업로드된 파일에서 추출된 원문 텍스트, LLM이 구조화한 분석 결과(JSON),
        사용자 검토 상태, 최종 확정된 Project 참조가 이 클래스에 누적됩니다.
    """@ko .

pm:rfpId
    a owl:DatatypeProperty ;
    rdfs:label "RFP 식별자"@ko ;
    rdfs:comment "시스템 내 고유 RFP ID. 예: 'RFP_001', 'RFP_ABCD1234EF'."@ko ;
    rdfs:domain pm:RFP ;
    rdfs:range xsd:string .

pm:fileName
    a owl:DatatypeProperty ;
    rdfs:label "원본 파일명"@ko ;
    rdfs:comment "업로드 시 원본 파일명. 예: '2025_스마트팩토리_제안요청서.pdf'."@ko ;
    rdfs:domain pm:RFP ;
    rdfs:range xsd:string .

pm:extractedText
    a owl:DatatypeProperty ;
    rdfs:label "추출 원문 텍스트"@ko ;
    rdfs:comment """
        PDF/DOCX/HWP에서 추출한 순수 텍스트. LLM 분석의 입력이 됩니다.
        매우 길 수 있으므로 클라이언트는 필요 시 페이지/섹션 단위로 분할해
        화면에 표시하는 것을 권장합니다.
    """@ko ;
    rdfs:domain pm:RFP ;
    rdfs:range xsd:string .

pm:pageCount
    a owl:DatatypeProperty ;
    rdfs:label "페이지/섹션 수"@ko ;
    rdfs:comment "PDF의 페이지 수. DOCX·HWP는 단락/섹션 수로 대체됩니다."@ko ;
    rdfs:domain pm:RFP ;
    rdfs:range xsd:integer .

pm:rfpStatus
    a owl:DatatypeProperty ;
    rdfs:label "RFP 상태"@ko ;
    rdfs:comment """
        RFP 처리 단계.
          - "extracted" : 업로드 완료, 텍스트 추출만 끝난 상태
          - "analyzed"  : LLM 분석 완료
          - "reviewed"  : 사용자가 결과를 수정·검토한 상태
          - "confirmed" : Project/Task 인스턴스로 온톨로지에 확정 적재됨
    """@ko ;
    rdfs:domain pm:RFP ;
    rdfs:range xsd:string .

pm:analysisJson
    a owl:DatatypeProperty ;
    rdfs:label "분석 결과 JSON"@ko ;
    rdfs:comment """
        LLM이 추출한 프로젝트 정보·WBS·필요 인력 구성을 담은 JSON 문자열.
        스키마는 API 응답(RfpAnalyzeResponse)과 동일합니다.
        사용자 검토 수정 결과도 이 필드에 병합 저장됩니다.
    """@ko ;
    rdfs:domain pm:RFP ;
    rdfs:range xsd:string .

pm:projectNameHint
    a owl:DatatypeProperty ;
    rdfs:label "프로젝트명(힌트)"@ko ;
    rdfs:comment """
        RFP 목록 조회 시 빠른 표시를 위해 분석 결과에서 추출한 프로젝트명을
        RFP 자체에 비정규화(denormalize)하여 저장합니다.
        확정 적재 시 생성되는 pm:Project 인스턴스의 pm:projectName과 연결됩니다.
    """@ko ;
    rdfs:domain pm:RFP ;
    rdfs:range xsd:string .

pm:confirmedProject
    a owl:ObjectProperty ;
    rdfs:label "확정된 프로젝트"@ko ;
    rdfs:comment """
        RFP가 'confirmed' 단계로 적재되면서 생성된 pm:Project 인스턴스의 링크.
        이후 인력 추천·WBS 진척 추적은 이 Project를 기준으로 수행됩니다.
    """@ko ;
    rdfs:domain pm:RFP ;
    rdfs:range pm:Project .


# ══════════════════════════════════════════════════════════════════
#  인스턴스 예시 (Example Instances)
#
#  실제 사용 예시로, 스키마가 어떻게 인스턴스화되는지 보여줍니다.
#  '핀테크 앱 개발' 프로젝트에서 기획자가 Figma를 수정하면
#  담당 개발자에게 알림이 가는 시나리오입니다.
# ══════════════════════════════════════════════════════════════════

# -- 사람 --
pm:person_alice
    a pm:Person ;
    pm:personId "P001" ;
    pm:personName "이앨리스" ;
    pm:role "기획자" ;
    pm:figmaUserId "figma_alice_001" ;
    pm:slackUserId "slack_alice_001" .

pm:person_bob
    a pm:Person ;
    pm:personId "P002" ;
    pm:personName "김밥" ;
    pm:role "프론트엔드 개발자" ;
    pm:githubLogin "bob-dev" ;
    pm:slackUserId "slack_bob_002" ;
    pm:availabilityScore "0.6"^^xsd:decimal .

# -- 역량 --
pm:skill_react
    a pm:Skill ;
    pm:skillId "SK001" ;
    pm:skillName "React" ;
    pm:skillCategory "TECHNICAL" ;
    pm:proficiencyLevel "0.88"^^xsd:decimal ;
    pm:skillEvidenceCount "47"^^xsd:integer .

pm:person_bob pm:hasSkill pm:skill_react .

# -- 프로젝트 --
pm:project_fintech
    a pm:Project ;
    pm:projectId "PRJ001" ;
    pm:projectName "핀테크 모바일 앱 v2" ;
    pm:projectDomain "핀테크" ;
    pm:techStack "React Native" ;
    pm:techStack "TypeScript" ;
    pm:techStack "Node.js" ;
    pm:difficultyLevel "HIGH" ;
    pm:projectStatus "ACTIVE" .

pm:person_alice pm:participatesIn pm:project_fintech .
pm:person_bob   pm:participatesIn pm:project_fintech .

# -- 디자인 컴포넌트 & Task --
pm:task_login_ui
    a pm:Task ;
    pm:taskId "T042" ;
    pm:taskName "로그인 화면 UI 구현" ;
    pm:wbsCode "2.1.3" ;
    pm:taskStatus "IN_PROGRESS" ;
    pm:progressPercent "55"^^xsd:integer ;
    pm:hasSourceFile "src/screens/auth/LoginScreen.tsx" ;
    pm:hasSourceFile "src/components/auth/LoginForm.tsx" ;
    pm:assignedTo pm:person_bob .

pm:project_fintech pm:hasTask pm:task_login_ui .

pm:component_login_screen
    a pm:DesignComponent ;
    pm:figmaFrameId "frame_9281ka" ;
    pm:componentName "LoginScreen" ;
    pm:figmaFileUrl "https://figma.com/file/abc123"^^xsd:anyURI ;
    pm:implementedBy pm:task_login_ui .

# -- 이벤트 → 의미 단위 → 알림 (시나리오 흐름) --
pm:event_design_001
    a pm:DesignEvent ;
    pm:eventId "EVT_D001" ;
    pm:eventSource "FIGMA" ;
    pm:eventTimestamp "2025-04-05T14:23:00Z"^^xsd:dateTime ;
    pm:figmaEventFrameId "frame_9281ka" ;
    pm:designChangeType "FRAME_MODIFIED" ;
    pm:designDiffSummary "로그인 버튼 위치 변경 및 에러 메시지 텍스트 스타일 수정" ;
    pm:performedBy pm:person_alice ;
    pm:relatedToComponent pm:component_login_screen .

pm:signal_design_change_001
    a pm:IssueSignal ;
    pm:semanticId "SEM001" ;
    pm:meaning "기획자가 LoginScreen Frame을 수정함. 로그인 버튼 레이아웃 변경으로 인해 LoginScreen.tsx 수정 필요" ;
    pm:confidenceScore "0.94"^^xsd:decimal ;
    pm:derivedFromEvent pm:event_design_001 ;
    pm:issueType "SCOPE_CHANGE" ;
    pm:issueSeverity "MEDIUM" ;
    pm:issueResolved "false"^^xsd:boolean ;
    pm:affectedTasks pm:task_login_ui .

pm:alert_001
    a pm:Alert ;
    pm:alertId "ALT001" ;
    pm:alertType "DESIGN_CHANGED" ;
    pm:alertTitle "[기획 변경] LoginScreen 수정 — 코드 반영 필요" ;
    pm:alertBody """기획자 이앨리스님이 LoginScreen Frame을 수정했습니다.
변경 내용: 로그인 버튼 위치 변경 및 에러 메시지 텍스트 스타일 수정
수정 필요 파일:
  - src/screens/auth/LoginScreen.tsx
  - src/components/auth/LoginForm.tsx
