# ──────────────────────────────────────────────────────────────────
#  디자인 컴포넌트 (DesignComponent) — Figma Frame 2개
#  BL-01 시나리오에서 기획자가 수정하는 컴포넌트들입니다.
# ──────────────────────────────────────────────────────────────────

inst:component_login_screen
    a owl:NamedIndividual, pm:DesignComponent ;
    pm:figmaFrameId "FRAME_9281KA" ;
    pm:componentName "LoginScreen" ;
    pm:figmaFileUrl "https://figma.com/file/payflow-v2/login"^^xsd:anyURI ;
    pm:implementedBy inst:task_login_ui .

inst:component_payment_flow
    a owl:NamedIndividual, pm:DesignComponent ;
    pm:figmaFrameId "FRAME_4472PB" ;
    pm:componentName "PaymentFlow" ;
    pm:figmaFileUrl "https://figma.com/file/payflow-v2/payment"^^xsd:anyURI ;
    pm:implementedBy inst:task_payment_ui .


# ══════════════════════════════════════════════════════════════════
#  [BL-01] 기획자 Figma 수정 → 개발자 맥락 알림
#
#  시나리오: 이하은(기획자)이 LoginScreen의 소셜 로그인 버튼 레이아웃을
#  변경했습니다. 시스템이 DesignEvent를 수신하고,
#  implementedBy → assignedTo 체인을 따라 김태양(개발자)에게
#  수정 필요 파일과 변경 내용을 담은 Slack 알림을 자동 발송합니다.
# ══════════════════════════════════════════════════════════════════

# WorkEvent: Figma webhook 수신
inst:event_figma_login_change
    a owl:NamedIndividual, pm:DesignEvent ;
    pm:eventId "EVT_D001" ;
    pm:eventSource "FIGMA" ;
    pm:eventTimestamp "2025-04-07T10:23:00Z"^^xsd:dateTime ;
    pm:figmaEventFrameId "FRAME_9281KA" ;
    pm:designChangeType "FRAME_MODIFIED" ;
    pm:affectedComponents "[\"SocialLoginButton\", \"LoginFormContainer\"]" ;
    pm:designDiffSummary "소셜 로그인 버튼(카카오·네이버)이 화면 하단에서 상단으로 이동. 로그인 폼과의 간격 24px → 16px 변경. '자동 로그인' 체크박스 추가." ;
    pm:rawPayload "{\"event\":\"file:update\",\"fileId\":\"payflow-v2\",\"frameId\":\"FRAME_9281KA\",\"editorId\":\"FIGMA_U002\"}" ;
    pm:performedBy inst:person_haeun ;
    pm:relatedToTask inst:task_login_ui ;
    pm:relatedToComponent inst:component_login_screen .

# SemanticUnit: IssueSignal (디자인 변경 → 코드 수정 필요)
inst:signal_login_design_change
    a owl:NamedIndividual, pm:IssueSignal ;
    pm:semanticId "SEM_D001" ;
    pm:meaning "기획자 이하은이 LoginScreen Frame을 수정함. 소셜 로그인 버튼 위치 변경 및 자동 로그인 체크박스 신규 추가로 인해 SocialLoginButton.tsx 및 LoginForm.tsx 수정 필요." ;
    pm:confidenceScore "0.93"^^xsd:decimal ;
    pm:derivedFromEvent inst:event_figma_login_change ;
    pm:interpretedAt "2025-04-07T10:23:08Z"^^xsd:dateTime ;
    pm:issueType "SCOPE_CHANGE" ;
    pm:issueSeverity "MEDIUM" ;
    pm:issueResolved "false"^^xsd:boolean ;
    pm:affectedTasks inst:task_login_ui .

# Alert: 김태양에게 Slack 알림 발송
inst:alert_login_design_change
    a owl:NamedIndividual, pm:Alert ;
    pm:alertId "ALT001" ;
    pm:alertType "DESIGN_CHANGED" ;
    pm:alertTitle "[기획 변경] LoginScreen 수정 — 코드 반영 필요 (WBS 1.0)" ;
    pm:alertBody """안녕하세요 김태양님, 기획자 이하은님이 LoginScreen을 수정했습니다.

■ 변경 내용
