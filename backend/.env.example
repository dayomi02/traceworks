# ════════════════════════════════════════════════════════
# Traceworks Backend — Environment Variables Template
#
# 사용법: 이 파일을 .env로 복사한 후 각 값을 실제 환경에 맞춰 채우세요.
#   cp .env.example .env
# ════════════════════════════════════════════════════════

# Runtime
ENV=development

# ─────────────────────────────────────────────────────────
# Database (MariaDB / MySQL via async)
# ─────────────────────────────────────────────────────────
DATABASE_URL=mysql+aiomysql://<user>:<password>@<host>:<port>/<dbname>

# ─────────────────────────────────────────────────────────
# Redis (Celery broker + cache)
# ─────────────────────────────────────────────────────────
REDIS_URL=redis://<host>:6379/0

# ─────────────────────────────────────────────────────────
# Apache Jena Fuseki (Triple Store)
# ─────────────────────────────────────────────────────────
FUSEKI_URL=http://<host>:3030/<dataset-name>
FUSEKI_ADMIN_USER=<admin-username>
FUSEKI_ADMIN_PASSWORD=<admin-password>

# ─────────────────────────────────────────────────────────
# OpenAI (LLM Interpreter)
# 발급: https://platform.openai.com/api-keys
# ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────
# Slack (선택 — 메시지 이벤트 수집용)
# ─────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ─────────────────────────────────────────────────────────
# GitHub Webhook (선택)
# ─────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────
# Google Slides / Drive (Service Account)
#
# 발급 절차:
#   GCP Console → IAM → Service Accounts → Keys → JSON 다운로드
#   Slides API + Drive API 활성화 필요
# ─────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_FILE=/secrets/google-sa.json
GOOGLE_SLIDES_FOLDER_ID=

# ─────────────────────────────────────────────────────────
# GitLab (선택 — 저장소 자동 생성/커밋 이벤트 수집용)
#
# 발급 절차:
#   GitLab → Preferences → Access Tokens → api scope
# ─────────────────────────────────────────────────────────
GITLAB_URL=http://<your-gitlab-host>
GITLAB_TOKEN=
GITLAB_NAMESPACE=<your-group-or-user>

# ─────────────────────────────────────────────────────────
# 알림 API (선택 — 외부 알림 서버 연동)
# ─────────────────────────────────────────────────────────
ALERT_API_URL=http://<your-alert-api-host>
ALERT_API_INTERNAL_TOKEN=

# ─────────────────────────────────────────────────────────
# Auth (JWT)
#   - JWT_SECRET은 반드시 강력한 랜덤 값으로 교체하세요.
#     생성 예: openssl rand -hex 32
# ─────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_ALGORITHM=HS256
