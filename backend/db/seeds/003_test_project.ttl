    pm:dueDate               "2026-07-10"^^xsd:date ;
    pm:plannedHours          "80.0"^^xsd:decimal ;
    pm:estimatedDays         "10.0"^^xsd:decimal ;
    pm:deliverable           "주문 워커 소스" ;
    pm:deliverable           "운영 매뉴얼" ;
    pm:assignedTo            inst:person_TEST_DEV1 ;
    pm:assigneeRole          "개발자" ;
    pm:implementsRequirement inst:req_RETAILOPS_R001_001 ;
    pm:dependsOn             inst:task_retailops_order_pl ;
