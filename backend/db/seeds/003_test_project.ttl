# ══════════════════════════════════════════════════════════════════
#  역할별 필요 인원 (RequiredRole)
# ══════════════════════════════════════════════════════════════════

inst:reqrole_retailops_pm a pm:RequiredRole ;
    pm:roleName          "PM" ;
    pm:requiredCount     "1"^^xsd:integer ;
    pm:requiredMM        "5.0"^^xsd:decimal ;
    pm:requiredTotalDays "110.0"^^xsd:decimal ;
    pm:requiredTotalHours "880.0"^^xsd:decimal ;
    pm:requiredTaskCount "1"^^xsd:integer ;
    pm:requiredSkill     "프로젝트 관리" ;
    pm:requiredSkill     "리테일 도메인" .

inst:reqrole_retailops_pl a pm:RequiredRole ;
    pm:roleName          "기획자" ;
    pm:requiredCount     "1"^^xsd:integer ;
    pm:requiredMM        "1.1"^^xsd:decimal ;
    pm:requiredTotalDays "25.0"^^xsd:decimal ;
    pm:requiredTotalHours "200.0"^^xsd:decimal ;
    pm:requiredTaskCount "5"^^xsd:integer ;
    pm:requiredSkill     "UX 기획" ;
    pm:requiredSkill     "요구사항 분석" .

inst:reqrole_retailops_dev a pm:RequiredRole ;
    pm:roleName          "개발자" ;
    pm:requiredCount     "1"^^xsd:integer ;
    pm:requiredMM        "8.0"^^xsd:decimal ;
    pm:requiredTotalDays "176.0"^^xsd:decimal ;
    pm:requiredTotalHours "1408.0"^^xsd:decimal ;
    pm:requiredTaskCount "11"^^xsd:integer ;
    pm:requiredSkill     "FastAPI" ;
    pm:requiredSkill     "PostgreSQL" ;
    pm:requiredSkill     "Kafka" ;
    pm:requiredSkill     "React" ;
    pm:requiredSkill     "Next.js" .

inst:project_retailops pm:requiresRole
    inst:reqrole_retailops_pm,
    inst:reqrole_retailops_pl,
    inst:reqrole_retailops_dev .

# ══════════════════════════════════════════════════════════════════
#  요구사항 — 대분류(REQ-XXX) + 중분류(REQ-XXX-YYY)
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
#  REQ-001 주문 통합 (대분류)
# ──────────────────────────────────────────────────────────────────

inst:req_RETAILOPS_R001 a pm:Requirement ;
    pm:requirementId          "REQ-001" ;
    pm:requirementName        "주문 통합" ;
    pm:requirementDescription "온라인몰·자사앱·매장 POS 등 모든 채널의 주문을 단일 백오피스에서 조회·관리할 수 있도록 통합한다." ;
    pm:requirementType        "기능" ;
    pm:requirementPriority    "HIGH" ;
    pm:requirementStatus      "APPROVED" ;
    pm:userType               "운영자" ;
    pm:relatedToProject       inst:project_retailops .

inst:req_RETAILOPS_R001_001 a pm:Requirement ;
    pm:requirementId          "REQ-001-001" ;
    pm:requirementName        "멀티채널 주문 동기화" ;
    pm:requirementDescription "온라인·매장 주문을 Kafka 기반 이벤트 큐로 수집, 중복 제거 후 백오피스 DB에 동기화" ;
    pm:requirementType        "기능" ;
    pm:requirementPriority    "HIGH" ;
    pm:requirementStatus      "APPROVED" ;
    pm:userType               "운영자" ;
    pm:relatedToProject       inst:project_retailops .

inst:req_RETAILOPS_R001_002 a pm:Requirement ;
    pm:requirementId          "REQ-001-002" ;
    pm:requirementName        "주문 상태 추적" ;
    pm:requirementDescription "결제→출고→배송→완료 전 흐름의 상태 추적 화면. 매장·고객·운영자가 각자 다른 뷰로 조회" ;
    pm:requirementType        "기능" ;
    pm:requirementPriority    "HIGH" ;
    pm:requirementStatus      "APPROVED" ;
    pm:userType               "운영자" ;
    pm:userType               "고객" ;
    pm:relatedToProject       inst:project_retailops .

# ──────────────────────────────────────────────────────────────────
#  REQ-002 재고 관리 (대분류)
# ──────────────────────────────────────────────────────────────────

inst:req_RETAILOPS_R002 a pm:Requirement ;
    pm:requirementId          "REQ-002" ;
    pm:requirementName        "재고 관리" ;
    pm:requirementDescription "매장-온라인 간 실시간 재고를 일관되게 유지. 부정합 발생 시 자동 보정·알림" ;
    pm:requirementType        "기능" ;
    pm:requirementPriority    "HIGH" ;
    pm:requirementStatus      "APPROVED" ;
    pm:userType               "운영자" ;
    pm:relatedToProject       inst:project_retailops .

inst:req_RETAILOPS_R002_001 a pm:Requirement ;
    pm:requirementId          "REQ-002-001" ;
    pm:requirementName        "실시간 재고 동기화" ;
    pm:requirementDescription "Redis 캐시 + PostgreSQL 트랜잭션 조합으로 매장·온라인 재고를 5초 이내 동기화. 충돌 시 보상 트랜잭션 적용" ;
    pm:requirementType        "기능" ;
    pm:requirementPriority    "HIGH" ;
    pm:requirementStatus      "APPROVED" ;
    pm:userType               "운영자" ;
    pm:relatedToProject       inst:project_retailops .

# ──────────────────────────────────────────────────────────────────
#  REQ-003 운영 대시보드 (대분류)
# ──────────────────────────────────────────────────────────────────

inst:req_RETAILOPS_R003 a pm:Requirement ;
    pm:requirementId          "REQ-003" ;
    pm:requirementName        "운영 대시보드" ;
    pm:requirementDescription "매장별 매출·방문객·재고회전을 한 화면에 시각화. 본부와 매장장이 같은 뷰로 의사결정" ;
    pm:requirementType        "기능" ;
    pm:requirementPriority    "MEDIUM" ;
    pm:requirementStatus      "APPROVED" ;
    pm:userType               "운영자" ;
    pm:userType               "매장장" ;
    pm:relatedToProject       inst:project_retailops .

inst:req_RETAILOPS_R003_001 a pm:Requirement ;
    pm:requirementId          "REQ-003-001" ;
    pm:requirementName        "매출·방문객 통합 지표" ;
    pm:requirementDescription "전일 매출, 시간대별 방문객, 재고 회전율 등 운영 KPI를 카드+차트로 표시" ;
    pm:requirementType        "기능" ;
    pm:requirementPriority    "MEDIUM" ;
    pm:requirementStatus      "APPROVED" ;
    pm:userType               "운영자" ;
    pm:userType               "매장장" ;
    pm:relatedToProject       inst:project_retailops .

# ──────────────────────────────────────────────────────────────────
#  REQ-004 멤버십 알림 (대분류) — Slides 웹훅 트리거 시나리오
# ──────────────────────────────────────────────────────────────────

inst:req_RETAILOPS_R004 a pm:Requirement ;
    pm:requirementId          "REQ-004" ;
    pm:requirementName        "멤버십 알림" ;
    pm:requirementDescription "회원 등급별 프로모션·재입고·포인트 만료 등을 푸시·이메일로 발송하는 알림 시스템" ;
    pm:requirementType        "기능" ;
    pm:requirementPriority    "MEDIUM" ;
    pm:requirementStatus      "APPROVED" ;
    pm:userType               "고객" ;
    pm:relatedToProject       inst:project_retailops .

inst:req_RETAILOPS_R004_001 a pm:Requirement ;
    pm:requirementId          "REQ-004-001" ;
    pm:requirementName        "푸시·이메일 발송" ;
    pm:requirementDescription "이벤트 트리거 기반 알림 발송 API + 어댑터 (FCM, SES). 발송 결과·열람률 집계 포함" ;
    pm:requirementType        "기능" ;
    pm:requirementPriority    "MEDIUM" ;
    pm:requirementStatus      "APPROVED" ;
    pm:userType               "고객" ;
    pm:relatedToProject       inst:project_retailops .

# ══════════════════════════════════════════════════════════════════
#  WBS 태스크
#  wbsCode 규약 : <대분류>.<중분류>.<역할>.<순번>  (예: 1.1.PL.1)
#  의존성: 기획(PL) → 개발(DEV) → 통합 안정화
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
#  0.PM.1 — 프로젝트 관리 (전체 기간, 진행 중)
# ──────────────────────────────────────────────────────────────────

inst:task_retailops_pm1 a pm:Task ;
    pm:taskId                "RETAILOPS001-T001" ;
    pm:wbsCode               "0.PM.1" ;
    pm:taskName              "프로젝트 관리" ;
    pm:taskDescription       "킥오프, 주간보고, 일정·리스크 관리, 발주사 커뮤니케이션, 산출물 검수" ;
    pm:taskStatus            "진행" ;
    pm:progressPercent       35 ;
    pm:plannedStart          "2026-06-01"^^xsd:date ;
    pm:dueDate               "2026-10-30"^^xsd:date ;
    pm:plannedHours          "880.0"^^xsd:decimal ;
    pm:estimatedDays         "110.0"^^xsd:decimal ;
    pm:deliverable           "킥오프 자료" ;
    pm:deliverable           "주간 보고서" ;
    pm:deliverable           "최종 종료 보고서" ;
    pm:assignedTo            inst:person_TEST_PM ;
    pm:assigneeRole          "PM" ;
    pm:phase                 "foundation" ;
    pm:criticality           "blocker" ;
    pm:risk                  "low" .

# ──────────────────────────────────────────────────────────────────
#  REQ-001-001 멀티채널 주문 동기화 — 기획 1 + 개발 2
# ──────────────────────────────────────────────────────────────────

inst:task_retailops_order_pl a pm:Task ;
    pm:taskId                "RETAILOPS001-T002" ;
    pm:wbsCode               "1.1.PL.1" ;
    pm:taskName              "주문 통합 화면 정의서" ;
    pm:taskDescription       "백오피스 주문 통합 화면 정의서 — 리스트·상세·필터·일괄 처리 흐름" ;
    pm:taskStatus            "완료" ;
    pm:progressPercent       100 ;
    pm:plannedStart          "2026-06-01"^^xsd:date ;
    pm:dueDate               "2026-06-05"^^xsd:date ;
    pm:plannedHours          "40.0"^^xsd:decimal ;
    pm:estimatedDays         "5.0"^^xsd:decimal ;
    pm:deliverable           "주문 통합 화면 정의서" ;
    pm:assignedTo            inst:person_TEST_PL ;
    pm:assigneeRole          "기획자" ;
    pm:implementsRequirement inst:req_RETAILOPS_R001_001 ;
    pm:phase                 "foundation" ;
    pm:criticality           "blocker" ;
    pm:risk                  "low" .

inst:task_retailops_order_dev1 a pm:Task ;
    pm:taskId                "RETAILOPS001-T003" ;
    pm:wbsCode               "1.1.DEV.1" ;
    pm:taskName              "멀티채널 주문 API 게이트웨이" ;
    pm:taskDescription       "온라인몰·자사앱·POS의 주문 API를 단일 게이트웨이로 추상화. 인증·rate-limit·재시도 정책 포함" ;
    pm:taskStatus            "진행" ;
    pm:progressPercent       40 ;
    pm:plannedStart          "2026-06-29"^^xsd:date ;
    pm:dueDate               "2026-07-10"^^xsd:date ;
    pm:plannedHours          "80.0"^^xsd:decimal ;
    pm:estimatedDays         "10.0"^^xsd:decimal ;
    pm:deliverable           "주문 게이트웨이 API 명세" ;
    pm:deliverable           "구현 코드 + 단위 테스트" ;
    pm:assignedTo            inst:person_TEST_DEV1 ;
    pm:assigneeRole          "개발자" ;
    pm:implementsRequirement inst:req_RETAILOPS_R001_001 ;
    pm:dependsOn             inst:task_retailops_order_pl ;
    pm:phase                 "core" ;
    pm:criticality           "blocker" ;
