inst:task_retailops_order_dev2 a pm:Task ;
    pm:taskId                "RETAILOPS001-T004" ;
    pm:wbsCode               "1.1.DEV.2" ;
    pm:taskName              "주문 큐 처리 워커" ;
    pm:taskDescription       "Kafka 주문 이벤트를 소비해 중복 제거 후 DB에 적재하는 워커. 백오피스 SSE로 실시간 푸시" ;
    pm:taskStatus            "진행" ;
