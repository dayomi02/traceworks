@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix pm:   <https://ontology.example.org/project-management#> .
@prefix inst: <https://ontology.example.org/instances#> .

# ══════════════════════════════════════════════════════════════════
#  옴니채널 리테일 운영 플랫폼 고도화 (RETAILOPS001)
#  ─ 2026 하반기 고도화 사업
#  ─ 발주사 : ㈜에버그린리테일
#  ─ 인력   : PM 1 / 기획자 1 / 개발자 1
#  ─ 통합   : Google Slides 알림 + GitLab CI 연동 (기존 통합 ID 유지)
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
#  조직 — 수행사
# ──────────────────────────────────────────────────────────────────

inst:org_RETAILOPS a pm:Organization ;
    pm:orgId   "ORG_RETAILOPS" ;
    pm:orgName "Dweax 리테일 사업본부" .

# ──────────────────────────────────────────────────────────────────
#  프로젝트
# ──────────────────────────────────────────────────────────────────

inst:project_retailops a pm:Project ;
    pm:projectId       "RETAILOPS001" ;
    pm:projectName     "옴니채널 리테일 운영 플랫폼 고도화" ;
    pm:projectStatus   "ACTIVE" ;
    pm:projectDomain   "리테일" ;
    pm:projectTheme    "오프라인 매장과 온라인 채널 통합 운영" ;
    pm:techStack       "React" ;
    pm:techStack       "Next.js" ;
    pm:techStack       "FastAPI" ;
    pm:techStack       "PostgreSQL" ;
    pm:techStack       "Redis" ;
    pm:techStack       "Kafka" ;
    pm:difficultyLevel "HIGH" ;
    pm:description     "오프라인 매장과 온라인 채널을 통합한 옴니채널 리테일 운영 플랫폼의 2026년 하반기 고도화 사업. 멀티채널 주문 통합, 실시간 재고 동기화, 매장 운영 대시보드, 멤버십 푸시·이메일 알림 시스템을 단계적으로 개선하여 매장-온라인 간 데이터 일관성과 운영 효율을 끌어올린다." ;
    pm:startDate       "2026-06-01"^^xsd:date ;
    pm:endDate         "2026-10-30"^^xsd:date ;
    pm:projectAmount   "480000000"^^xsd:integer ;
    pm:budget          "4억 8천만원" ;
    pm:contractType    "확정금액" ;
    pm:businessType    "고도화" ;
    pm:leadCompany     "Dweax" ;
    pm:clientName      "㈜에버그린리테일" ;
    pm:googleSlideId   "1lAmfHQSYE1ZkaEnzK1CynBvl6-xrdp5Nwagr4zLsasE" ;
    pm:gitlabProjectId "7" ;
    pm:gitlabRepoUrl   "http://dweax.iptime.org:50004/root/alert-test-project"^^xsd:anyURI ;
    pm:ownedBy         inst:org_RETAILOPS .

# ══════════════════════════════════════════════════════════════════
#  인력 (4명 유지) — 002_persons.ttl과는 별개의 프로젝트 전용 인스턴스
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
#  PM — 홍길동
# ──────────────────────────────────────────────────────────────────

inst:person_TEST_PM a pm:Person ;
    pm:personId          "TEST_PM" ;
    pm:personName        "홍길동" ;
    pm:role              "PM" ;
    pm:grade             "수석" ;
    pm:availabilityScore "0.80"^^xsd:decimal ;
    pm:belongsTo         inst:org_RETAILOPS ;
    pm:participatesIn    inst:project_retailops ;
    pm:hasSkill          inst:skill_TEST_PM_1, inst:skill_TEST_PM_2, inst:skill_TEST_PM_3 .

inst:skill_TEST_PM_1 a pm:Skill ;
    pm:skillName        "프로젝트 관리" ;
    pm:skillCategory    "SOFT_SKILL" ;
    pm:proficiencyLevel "0.92"^^xsd:decimal .

inst:skill_TEST_PM_2 a pm:Skill ;
    pm:skillName        "일정 관리" ;
    pm:skillCategory    "SOFT_SKILL" ;
    pm:proficiencyLevel "0.88"^^xsd:decimal .

inst:skill_TEST_PM_3 a pm:Skill ;
    pm:skillName        "리테일 도메인" ;
    pm:skillCategory    "DOMAIN" ;
    pm:proficiencyLevel "0.85"^^xsd:decimal .

# ──────────────────────────────────────────────────────────────────
