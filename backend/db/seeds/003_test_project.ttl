# ──────────────────────────────────────────────────────────────────
#  REQ-001-002 주문 상태 추적 — 기획 1 + 개발 2
# ──────────────────────────────────────────────────────────────────

inst:task_retailops_orderstatus_pl a pm:Task ;
    pm:taskId                "RETAILOPS001-T005" ;
    pm:wbsCode               "1.2.PL.1" ;
    pm:taskName              "주문 상태 흐름도 설계" ;
