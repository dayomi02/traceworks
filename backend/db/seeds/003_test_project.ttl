inst:person_TEST_PL a pm:Person ;
    pm:personId          "TEST_PL" ;
    pm:personName        "이기획" ;
    pm:role              "기획자" ;
    pm:grade             "선임" ;
    pm:availabilityScore "0.90"^^xsd:decimal ;
    pm:belongsTo         inst:org_RETAILOPS ;
    pm:participatesIn    inst:project_retailops ;
    pm:hasSkill          inst:skill_TEST_PL_1, inst:skill_TEST_PL_2, inst:skill_TEST_PL_3 .

inst:skill_TEST_PL_1 a pm:Skill ;
    pm:skillName        "UX 기획" ;
    pm:skillCategory    "DOMAIN" ;
    pm:proficiencyLevel "0.90"^^xsd:decimal .

inst:skill_TEST_PL_2 a pm:Skill ;
