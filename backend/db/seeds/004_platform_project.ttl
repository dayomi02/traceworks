@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix pm:   <https://ontology.example.org/project-management#> .
@prefix inst: <https://ontology.example.org/instances#> .

# ══════════════════════════════════════════════════════════════════
#  플랫폼 개발 프로젝트 (PLT001) — 통합 업무 관리 플랫폼
#  기간 : 2026-06-01 ~ 2026-10-30 (5개월, 약 110 영업일)
#  인력 : 002_persons.ttl의 PM001(PM) / PL001(기획자) / DEV001(개발자)
#         3명을 본 프로젝트에 참여시킴 (pm:participatesIn 트리플 추가)
#  핵심 화면 : 로그인 화면, 마이페이지 화면 — 각각 기획+개발 분리 진행
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
#  조직
# ──────────────────────────────────────────────────────────────────

inst:org_PLT a pm:Organization ;
    pm:orgId   "ORG_PLT" ;
    pm:orgName "Dweax 플랫폼 본부" .

# ──────────────────────────────────────────────────────────────────
#  프로젝트
# ──────────────────────────────────────────────────────────────────

inst:project_plt001 a pm:Project ;
    pm:projectId       "PLT001" ;
    pm:projectName     "통합 업무 관리 플랫폼 구축" ;
    pm:projectStatus   "ACTIVE" ;
    pm:projectDomain   "B2B SaaS" ;
    pm:projectTheme    "사내 업무 효율화 플랫폼" ;
    pm:techStack       "React" ;
    pm:techStack       "TypeScript" ;
    pm:techStack       "FastAPI" ;
    pm:techStack       "PostgreSQL" ;
    pm:difficultyLevel "MEDIUM" ;
    pm:description     "조직 전체의 업무·일정·문서를 한곳에서 관리할 수 있는 B2B SaaS 플랫폼. 사용자 인증, 마이페이지, 대시보드, 실시간 알림 기능을 단계적으로 구축한다." ;
    pm:startDate       "2026-06-01"^^xsd:date ;
    pm:endDate         "2026-10-30"^^xsd:date ;
    pm:projectAmount   "350000000"^^xsd:integer ;
    pm:budget          "3억 5천만원" ;
    pm:contractType    "확정금액" ;
    pm:businessType    "신규 구축" ;
    pm:leadCompany     "Dweax" ;
    pm:ownedBy         inst:org_PLT ;
    pm:googleSlideId   "179YsK1dfr4nySROubKHfRKgIVgax87AplMFJ3Q9LPWs" ;
    pm:gitlabProjectId "24" ;
    pm:gitlabRepoUrl   "http://dweax.iptime.org:50004/mvp/mvp-demo.git" .

# ──────────────────────────────────────────────────────────────────
#  인력 참여 — 002_persons.ttl의 기존 Person URI에 트리플만 추가
# ──────────────────────────────────────────────────────────────────

inst:person_PM001
    pm:belongsTo      inst:org_PLT ;
    pm:participatesIn inst:project_plt001 .

inst:person_PL001
    pm:belongsTo      inst:org_PLT ;
    pm:participatesIn inst:project_plt001 .

inst:person_DEV001
    pm:belongsTo      inst:org_PLT ;
    pm:participatesIn inst:project_plt001 .

# ──────────────────────────────────────────────────────────────────
#  역할별 필요 인원 (RequiredRole)
# ──────────────────────────────────────────────────────────────────

inst:reqrole_plt001_pm a pm:RequiredRole ;
    pm:roleName          "PM" ;
    pm:requiredCount     "1"^^xsd:integer ;
    pm:requiredMM        "5.0"^^xsd:decimal ;
    pm:requiredTotalDays "110.0"^^xsd:decimal ;
    pm:requiredTotalHours "880.0"^^xsd:decimal ;
    pm:requiredTaskCount "1"^^xsd:integer ;
    pm:requiredSkill     "프로젝트 관리" ;
    pm:requiredSkill     "일정 관리" ;
    pm:requiredSkill     "리스크 관리" .

inst:reqrole_plt001_pl a pm:RequiredRole ;
    pm:roleName          "기획자" ;
    pm:requiredCount     "1"^^xsd:integer ;
    pm:requiredMM        "0.7"^^xsd:decimal ;
    pm:requiredTotalDays "15.0"^^xsd:decimal ;
    pm:requiredTotalHours "120.0"^^xsd:decimal ;
    pm:requiredTaskCount "3"^^xsd:integer ;
    pm:requiredSkill     "요구사항 분석" ;
    pm:requiredSkill     "UX 기획" ;
    pm:requiredSkill     "화면 정의서" .

inst:reqrole_plt001_dev a pm:RequiredRole ;
    pm:roleName          "개발자" ;
    pm:requiredCount     "1"^^xsd:integer ;
    pm:requiredMM        "4.3"^^xsd:decimal ;
    pm:requiredTotalDays "95.0"^^xsd:decimal ;
    pm:requiredTotalHours "760.0"^^xsd:decimal ;
    pm:requiredTaskCount "8"^^xsd:integer ;
    pm:requiredSkill     "React" ;
    pm:requiredSkill     "TypeScript" ;
    pm:requiredSkill     "FastAPI" ;
    pm:requiredSkill     "PostgreSQL" .

inst:project_plt001 pm:requiresRole
    inst:reqrole_plt001_pm,
    inst:reqrole_plt001_pl,
    inst:reqrole_plt001_dev .

# ══════════════════════════════════════════════════════════════════
#  요구사항 — 대분류(REQ-XXX) + 중분류(REQ-XXX-YYY)
#  대분류는 부모 컨테이너 역할, 실제 WBS는 중분류 단위로 연결
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
#  REQ-001 사용자 인증 (대분류)  ※ 로그인 화면 포함 — 필수
# ──────────────────────────────────────────────────────────────────

inst:req_PLT001_R001 a pm:Requirement ;
    pm:requirementId          "REQ-001" ;
    pm:requirementName        "사용자 인증" ;
    pm:requirementDescription "이메일·소셜 로그인, 회원가입, 세션 관리 등 사용자 인증 체계 전반" ;
    pm:requirementType        "기능" ;
    pm:requirementPriority    "HIGH" ;
    pm:requirementStatus      "APPROVED" ;
    pm:userType               "사용자" ;
    pm:relatedToProject       inst:project_plt001 .

inst:req_PLT001_R001_001 a pm:Requirement ;
    pm:requirementId          "REQ-001-001" ;
    pm:requirementName        "로그인 화면" ;
    pm:requirementDescription "이메일/비밀번호 입력 및 소셜 로그인 버튼이 포함된 로그인 화면. 잘못된 입력 시 인라인 에러 표시." ;
    pm:requirementType        "기능" ;
    pm:requirementPriority    "HIGH" ;
    pm:requirementStatus      "APPROVED" ;
    pm:userType               "사용자" ;
    pm:relatedToProject       inst:project_plt001 .

inst:req_PLT001_R001_002 a pm:Requirement ;
    pm:requirementId          "REQ-001-002" ;
    pm:requirementName        "회원가입" ;
    pm:requirementDescription "이메일 인증 기반 회원가입 API 및 입력 검증" ;
    pm:requirementType        "기능" ;
    pm:requirementPriority    "MEDIUM" ;
    pm:requirementStatus      "APPROVED" ;
    pm:userType               "사용자" ;
    pm:relatedToProject       inst:project_plt001 .

# ──────────────────────────────────────────────────────────────────
#  REQ-002 마이페이지 (대분류)  ※ 마이페이지 화면 포함 — 필수
