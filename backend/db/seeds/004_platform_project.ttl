# ══════════════════════════════════════════════════════════════════
#  WBS 태스크
#  - wbsCode 규약 : <대분류>.<중분류>.<역할>.<순번>  (예: 1.1.PL.1)
#  - PM 태스크는 0.PM.1로 별도 표기
#  - 의존성: 기획(PL) → 개발(DEV) → 통합(QA) 순
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
#  0.PM.1 — 프로젝트 관리 (전체 기간)
# ──────────────────────────────────────────────────────────────────

inst:task_plt001_pm1 a pm:Task ;
    pm:taskId                "PLT001-T001" ;
    pm:wbsCode               "0.PM.1" ;
    pm:taskName              "프로젝트 관리" ;
    pm:taskDescription       "킥오프, 주간보고, 일정·리스크 관리, 산출물 검수, 고객 커뮤니케이션" ;
    pm:taskStatus            "진행" ;
    pm:progressPercent       30 ;
    pm:plannedStart          "2026-06-01"^^xsd:date ;
    pm:dueDate               "2026-10-30"^^xsd:date ;
    pm:plannedHours          "880.0"^^xsd:decimal ;
    pm:estimatedDays         "110.0"^^xsd:decimal ;
    pm:deliverable           "킥오프 자료, 주간보고서, 종료 보고서" ;
    pm:assignedTo            inst:person_PM001 ;
    pm:assigneeRole          "PM" ;
    pm:phase                 "foundation" ;
    pm:criticality           "blocker" ;
    pm:risk                  "low" .

